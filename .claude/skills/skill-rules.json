{
  "observe-act-loop": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "medium",
    "promptTriggers": {
      "keywords": [
        "run tests",
        "pytest",
        "test it",
        "submit",
        "deploy",
        "resubmit",
        "verify",
        "check if it works",
        "debug",
        "why is it failing",
        "check logs",
        "tail logs",
        "watch",
        "diagnose"
      ],
      "intentPatterns": [
        "(run|execute|launch|start|submit|deploy).*?(test|job|server|service)",
        "(verify|check|validate|confirm).*?(works|correct|fixed|passes)",
        "(debug|diagnose|investigate).*?(error|failure|crash|timeout)"
      ]
    }
  },
  "query-logs": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "medium",
    "promptTriggers": {
      "keywords": [
        "query logs",
        "check logs",
        "pod logs",
        "victoria logs",
        "search logs",
        "find in logs",
        "log query"
      ],
      "intentPatterns": [
        "(query|search|check|find|look at|grep).*?(logs?|output|stderr)",
        "(what|why).*?(log|error|crash|traceback).*?(say|show|contain)"
      ]
    }
  },
  "monitor-job": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "medium",
    "promptTriggers": {
      "keywords": [
        "monitor",
        "watch job",
        "background agent",
        "check job status",
        "submit and watch",
        "keep an eye on"
      ],
      "intentPatterns": [
        "(monitor|watch|track|check on).*?(job|pod|training|inference|deploy)",
        "(submit|launch).*?(monitor|watch|background)"
      ]
    }
  },
  "log-first-failure": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "promptTriggers": {
      "keywords": [
        "first failure",
        "timeline",
        "cascading errors",
        "watchdog timeout",
        "collective timeout",
        "find root cause from logs"
      ],
      "intentPatterns": [
        "(find|identify|locate).*?(first|earliest).*?(error|failure)",
        "(build|make|create).*?(timeline).*?(failure|incident|crash)",
        "(separate|distinguish).*?(root cause|cause).*?(cascade|downstream)"
      ]
    }
  },
  "upstream-bug-report": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "medium",
    "promptTriggers": {
      "keywords": [
        "upstream issue",
        "file issue",
        "bug report",
        "open issue",
        "rfc comment",
        "minimal reproduction"
      ],
      "intentPatterns": [
        "(file|create|open|write|draft).*?(issue|bug report|report)",
        "(comment|reply).*?(rfc|issue)",
        "(summarize|convert|turn).*?(debug|findings).*?(issue|report)"
      ]
    }
  }
}
